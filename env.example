# Required: Calendly event base URL (no date/time path segments).
# The bot picks a date and time on its own based on the preferences below.
BOOKING_URL=https://calendly.com/your-org/30min

# --- Date / time selection -------------------------------------------------
# One env var per weekday, comma-separated times in priority order (24h HH:MM).
# Omit a weekday to skip it entirely. The bot only consults today's weekday
# on each run, so a daily cron will book each weekday separately.
BOOKING_PREF_MONDAY=07:00,07:30,18:00
BOOKING_PREF_TUESDAY=18:00,18:30
BOOKING_PREF_WEDNESDAY=07:00
# BOOKING_PREF_THURSDAY=...
# BOOKING_PREF_FRIDAY=...
# BOOKING_PREF_SATURDAY=...
# BOOKING_PREF_SUNDAY=...

# How far ahead to search (days). The bot picks the FURTHEST-OUT matching
# weekday within this window so the slot is locked in early.
BOOKING_LOOKAHEAD_DAYS=60

# Optional: dates to never book on (ISO YYYY-MM-DD, comma-separated).
# BOOKING_SKIP_DATES=2026-05-25,2026-07-04

# --- Form fields -----------------------------------------------------------
# Any other BOOKING_* env var maps to a form field on the booking page. The
# suffix is converted to a label fragment (BOOKING_PHONE_NUMBER -> "phone number").
BOOKING_NAME=Your Name
BOOKING_EMAIL=you@example.com
# BOOKING_PHONE_NUMBER=5125551234

# Optional: set to "false" to run with a visible browser (for debugging).
# HEADLESS=true

# Optional: set to "true" to skip the final submit click. Form gets filled
# and the submit button is highlighted in red in the screenshot, but no
# booking is actually made. Useful for verifying field population.
# DRY_RUN=true

# Optional: how many days of past screenshot runs to keep under
# screenshots/. Older run directories are deleted at the start of each run.
# Set to 0 to disable pruning entirely.
# SCREENSHOT_RETENTION_DAYS=15

