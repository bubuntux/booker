# Required: Full Calendly URL with date/time
BOOKING_URL=https://calendly.com/xxxx/30min/2026-04-23T13:30:00-05:00?back=1&month=2026-04&date=2026-04-23

# Form fields: any env var starting with BOOKING_ (except BOOKING_URL) maps to a form field.
# The suffix is converted to a label: BOOKING_PHONE_NUMBER -> matches "phone number"
BOOKING_NAME=Your Name
BOOKING_EMAIL=you@example.com
# BOOKING_PHONE_NUMBER=5125551234

# Optional: set to "false" to run with visible browser (for debugging)
# HEADLESS=true
